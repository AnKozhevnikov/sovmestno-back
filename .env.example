# Local Development Environment Configuration
# Copy this file to .env for local development

# PostgreSQL
POSTGRES_DB=sovmestno_dev
POSTGRES_USER=sovmestno_user
POSTGRES_PASSWORD=dev_password_123

# Database connection for services
DB_DSN=postgres://sovmestno_user:dev_password_123@postgres:5432/sovmestno_dev?sslmode=disable

# Redis
REDIS_URL=redis:6379

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password_123
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password_123

# Gateway
GATEWAY_PORT=8080
GIN_MODE=debug
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
API_HOST=localhost:8080

# JWT Secret
JWT_SECRET=dev_jwt_secret_key_change_in_production

# Admin Secret Key
ADMIN_SECRET_KEY=dev_admin_secret_key_change_in_production

# Microservices
USER_SERVICE_PORT=8081
USER_SERVICE_URL=http://user-service:8081

EVENT_SERVICE_PORT=8082
EVENT_SERVICE_URL=http://event-service:8082

APPLICATION_SERVICE_PORT=8083
APPLICATION_SERVICE_URL=http://application-service:8083

# Grafana Admin Password
GRAFANA_ADMIN_PASSWORD=admin

# pgAdmin credentials
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
